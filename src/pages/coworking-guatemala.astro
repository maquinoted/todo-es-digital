---
import MainLayout from '../layouts/MainLayout.astro';
const currentCanonicalURL = "https://todoesdigital.com/coworking-guatemala";
import ContactForm from '../components/ContactForm.astro';

// Optimizamos las imágenes definiendo dimensiones para evitar CLS
const images = [
  { src: "/coworking-guatemala.webp", alt: "Coworking en Guatemala | Desde Q75 el día | Zona Pradera, zona 10" },
  { src: "/cowork-guatemala-zona10.webp", alt: "Oficinas compartidas en Zona Pradera" },
  { src: "/oficina-virtual-guatemala.webp", alt: "Renta de espacios de trabajo flexibles" },
  { src: "/salas-reuniones-renta-guatemala.webp", alt: "Salas de reuniones en coworking Guatemala" }
];
---

<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Todo es Digital - Coworking Guatemala",
    "image": "https://todoesdigital.com/coworking-guatemala.webp",
    "@id": "https://todoesdigital.com/coworking-guatemala",
    "url": "https://todoesdigital.com/coworking-guatemala",
    "telephone": "+50223022200",
    "priceRange": "Q75 - Q165",
    "description": "Trabaje en el centro de negocios más exclusivo de Guatemala. Coworking en Zona Pradera con internet simétrico, café ilimitado y parqueo seguro. ¡Tu oficina lista hoy mismo en Zona 10!",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Torre 2, Oficina 1108, Zona Pradera",
      "addressLocality": "Ciudad de Guatemala",
      "addressRegion": "Guatemala",
      "postalCode": "01010",
      "addressCountry": "GT"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 14.5912,
      "longitude": -90.4851
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "17:00"
    }
  }
</script>

<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [{
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://todoesdigital.com/"
    },{
      "@type": "ListItem",
      "position": 2,
      "name": "Coworking en Guatemala",
      "item": "https://todoesdigital.com/coworking-guatemala"
    }]
  }
</script>

<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Qué servicios incluye el pase diario en Zona Pradera?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El pase diario incluye acceso a estaciones de trabajo ergonómicas, internet simétrico de alta velocidad, café premium ilimitado, agua pura y climatización en Torre 2, Oficina 1108 de Zona Pradera."
        }
      },
      {
        "@type": "Question",
        "name": "¿Es necesario contrato para usar las oficinas compartidas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, ofrecemos una modalidad de oficina flexible sin contratos forzosos ni depósitos de garantía, ideal para nómadas digitales y consultores en Zona 10."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuentan con internet estable para reuniones virtuales?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí, contamos con infraestructura de fibra óptica redundante y simétrica que garantiza estabilidad absoluta para Zoom, Teams o Google Meet."
        }
      }
    ]
  }
</script>

<MainLayout
  title="Coworking en Guatemala | Zona Pradera | Oficina Flexible Q100 🚀"
  description="Trabaje en el centro de negocios más exclusivo de Guatemala. Coworking en Zona Pradera con internet simétrico, café ilimitado y parqueo seguro. ¡Tu oficina lista hoy mismo en Zona 10!"
  canonicalURL={currentCanonicalURL}
>

  <article class="container">
    <h1 class="hero-clean-title">Coworking en Guatemala: <span class="text-accent">Espacios de Trabajo</span> en Zona Pradera</h1>
    
    <div class="hero-grid">
      <div class="column-left gallery-square-grid">
        {images.map((img) => (
          <div class="img-container">
             <img 
              src={img.src} 
              alt={img.alt} 
              width="215" 
              height="215" 
              loading="eager" 
              decoding="async"
              class="img-square" 
            />
          </div>
        ))}
      </div>

      <div class="column-right">
        <p class="lead">
          Optimice su jornada laboral en la ubicación de negocios más estratégica de la ciudad. Ubicados en <strong>Torre 2, Oficina 1108 de Zona Pradera</strong>, ofrecemos una solución profesional de <strong>coworking en Guatemala</strong> para quienes exigen conectividad total y un entorno corporativo impecable.
        </p>

        <div class="pricing-container">
          <div class="price-card">
            <h3>Pase Diario de Coworking</h3>
            <p class="amount">Q165<span>/ persona</span></p>
          </div>
          <div class="price-card highlight">
            <h3>Pase 4 Horas (Medio Día)</h3>
            <p class="amount">Q100<span>/ persona</span></p>
          </div>
        </div>
        
        <p class="bullet-highlights">
          <span class="dot"></span> Acceso inmediato | <span class="dot"></span> Sin contratos forzosos | <span class="dot"></span> Ambiente 100% corporativo
        </p>
        
        <a href="https://wa.me/50223022200?text=Quiero%20reservar%20mi%20espacio%20de%20coworking" class="btn-primary">Reservar Espacio de Coworking</a>
      </div>
    </div>

    <section class="educational-section">
        <h2 class="section-title">¿Qué es el Coworking en Guatemala y por qué es tendencia?</h2>
        <p class="small-p">
          El <strong>coworking en Guatemala</strong> ha evolucionado para convertirse en la nueva modalidad de trabajo para el ecosistema empresarial. No se trata solo de "alquilar un escritorio", sino de acceder a un entorno de alto nivel que potencia la eficiencia de su operación.
        </p>
        <div class="advantage-grid">
            <div class="advantage-item">
              <h3>Para Empresas</h3>
              <p>Reduzca costos fijos de mantenimiento. Establezca células de trabajo en Zona 10 con flexibilidad total.</p>
            </div>
            <div class="advantage-item">
              <h3>Para Emprendedores</h3>
              <p>Transiciona de una imagen doméstica a una presencia corporativa, fundamental para cerrar negocios y proyectar solidez.</p>
            </div>
            <div class="advantage-item">
              <h3>Para Profesionales</h3>
              <p>La solución al internet inestable y la falta de privacidad con estándares AAA para consultores y especialistas.</p>
            </div>
        </div>
    </section>

    <section class="benefits-section">
      <h2 class="text-center section-title">Beneficios de elegir nuestras Oficinas Compartidas en Guatemala</h2>
      <div class="grid-3">
        <div class="benefit-card">
          <div class="icon-bg">🎯</div>
          <h3>Concentración Absoluta</h3>
          <p>Elimine el ruido doméstico y las distracciones de las cafeterías públicas para un enfoque total.</p>
        </div>
        <div class="benefit-card">
          <div class="icon-bg">⚡</div>
          <h3>Infraestructura de Red</h3>
          <p>Internet simétrico redundante. Garantizamos estabilidad para sus videoconferencias sin caídas.</p>
        </div>
        <div class="benefit-card">
          <div class="icon-bg">📍</div>
          <h3>Ubicación Estratégica</h3>
          <p>Sitúe su base en el complejo corporativo más importante, facilitando sus gestiones en Zona 10.</p>
        </div>
      </div>
    </section>

    <section class="details-section">
      <h2 class="text-center section-title">Acerca del servicio de coworking</h2>
      <div class="details-grid">
        <div class="details-card inclusions">
          <h4>¿Qué incluye su pase?</h4>
          <ul class="check-list">
            <li>Uso de estación de trabajo profesional</li>
            <li>Internet simétrico de alta velocidad</li>
            <li>Estación de Café y Té premium ilimitado</li>
            <li>Agua pura ilimitada</li>
            <li>Climatización controlada (A/C)</li>
            <li>Acceso a áreas comunes y sanitarios</li>
          </ul>
        </div>
        <div class="details-card requirements">
          <h4>Términos de Uso y Reserva</h4>
          <ul class="info-list">
            <li><strong>Ubicación Exacta:</strong> Torre 2, Oficina 1108.</li>
            <li><strong>Reserva:</strong> Requiere pago del 100% anticipado.</li>
            <li><strong>Ingreso:</strong> Presentación de identificación obligatoria.</li>
            <li><strong>Parqueo:</strong> Tarifa preferencial de Q9.00/hora.</li>
            <li class="restricted-item"><strong>Exclusiones:</strong> No incluye sala de reuniones ni domicilio fiscal.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <h2 class="text-center section-title">Preguntas Frecuentes sobre Coworking en Guatemala</h2>
      <div class="faq-grid">
          <div class="faq-item">
              <h3>¿Qué servicios incluye el pase diario en Zona Pradera?</h3>
              <p>Al reservar tu <strong>pase diario de coworking en Guatemala</strong>, obtienes acceso total a nuestras estaciones de trabajo, conexión de <strong>internet simétrico de alta velocidad</strong>, café ilimitado, agua pura y Aire acondicionado. Todo en un ambiente corporativo de alto nivel en la Torre 2 de Zona Pradera.</p>
          </div>
          <div class="faq-item">
              <h3>¿Es necesario contrato para usar las oficinas compartidas?</h3>
              <p>No, nuestra propuesta de <strong>oficina flexible</strong> permite trabajar sin contratos forzosos ni depósitos de garantía. Puedes optar por pases de medio día o días completos, adaptándonos a las necesidades de <strong>nómadas digitales</strong> y empresas en <strong>Zona 10</strong>.</p>
          </div>
          <div class="faq-item">
              <h3>¿Cuentan con internet estable para reuniones virtuales?</h3>
              <p>Sí, la infraestructura de red en <strong>Todo es Digital</strong> está diseñada para profesionales. Contamos con fibra óptica redundante que garantiza estabilidad absoluta para Zoom, Teams o Google Meet, eliminando las caídas comunes de las redes domésticas.</p>
          </div>
          <div class="faq-item">
              <h3>¿Dónde se ubica exactamente el coworking en Zona Pradera?</h3>
              <p>Estamos ubicados estratégicamente en la <strong>Torre 2, Oficina 1108</strong>. Zona Pradera es el complejo corporativo más seguro y moderno de la Ciudad de Guatemala, ofreciendo parqueo techado y acceso inmediato a Zona 10.</p>
          </div>
      </div>
    </section>

    <section class="contact-split">
      <div class="contact-info-side">
        <h4>Reserve su espacio en Zona Pradera</h4>
        <div class="quick-links">
          <p class="location-tag">📍 Torre 2, Oficina 1108, Zona Pradera.</p>
          <p class="time-tag">🕒 Lunes a Viernes (8:00 AM - 5:00 PM)</p>
          <a href="https://wa.me/50223022200" class="whatsapp-link">WhatsApp: +502 2302 2200</a>
        </div>
      </div>
      <div class="form-side-compact">
        <ContactForm serviceName="Coworking Torre 2" formId="mgolzeyp" />
      </div>
    </section>
  </article>
</MainLayout>

<style>
  :root {
    --primary: #007a73;       /* Oscurecido para accesibilidad */
    --primary-dark: #005c57; 
    --primary-light: #e6f7f6;
    --dark: #111827;         
    --grey-text: #374151;     /* Oscurecido para legibilidad */
    --white: #ffffff;
  }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 20px 60px; font-family: sans-serif; }
  .text-accent { color: var(--primary); }
  .text-center { text-align: center; }

  .hero-clean-title { 
    font-size: 2.2rem; 
    color: var(--dark); 
    margin: 40px 0 30px; 
    text-align: center; 
    font-weight: 800; 
    min-height: 2.4em; 
  }

  .hero-grid { display: grid; grid-template-columns: 450px 1fr; gap: 40px; align-items: start; margin-bottom: 60px; }
  .gallery-square-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  
  .img-container { 
    aspect-ratio: 1 / 1; 
    background: #f0f0f0; 
    border-radius: 12px; 
    overflow: hidden; 
  }

  .img-square { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    display: block;
  }

  .pricing-container { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin: 20px 0; }
  .price-card { background: var(--white); border: 1px solid #e5e7eb; padding: 20px; border-radius: 16px; text-align: center; }
  .price-card.highlight { border: 2px solid var(--primary); background: var(--primary-light); }
  .price-card h3 { color: var(--primary-dark); font-size: 0.85rem; margin: 0 0 10px 0; font-weight: 700; text-transform: uppercase; }
  .price-card .amount { font-size: 1.8rem; font-weight: 800; color: var(--dark); }
  .price-card .amount span { font-size: 0.8rem; color: var(--grey-text); }
  
  .lead { font-size: 1rem; line-height: 1.6; color: var(--grey-text); margin-bottom: 20px; }
  .bullet-highlights { font-size: 0.9rem; font-weight: 700; color: var(--primary-dark); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
  .dot { width: 4px; height: 4px; background: var(--primary); border-radius: 50%; }

  .btn-primary { 
    display: inline-block; padding: 16px 32px; background: var(--primary); color: white !important; 
    text-decoration: none; border-radius: 100px; font-weight: 700; font-size: 0.95rem; 
    transition: transform 0.2s;
  }
  .btn-primary:hover { background: var(--dark); transform: translateY(-2px); }

  .section-title { font-size: 1.8rem; font-weight: 800; color: var(--dark); margin-bottom: 20px; }

  .educational-section { padding: 50px 40px; background: var(--white); border-radius: 30px; margin: 40px 0; border: 1px solid #f3f4f6; }
  .advantage-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; }
  .advantage-item h3 { color: var(--primary); font-size: 1.1rem; margin-bottom: 10px; font-weight: 700; }
  .advantage-item p { text-align: left; font-size: 0.9rem; line-height: 1.5; color: var(--grey-text); }

  .benefits-section { padding: 40px 0; }
  .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; }
  .benefit-card { padding: 30px 25px; border-radius: 20px; background: var(--white); border: 1px solid #f3f4f6; }
  .icon-bg { font-size: 1.8rem; margin-bottom: 15px; display: block; }
  .benefit-card h3 { color: var(--dark); margin-bottom: 10px; font-weight: 800; font-size: 1.1rem; }
  .benefit-card p { font-size: 0.9rem; line-height: 1.5; }

  .details-section { padding: 50px 0; background: #f9fafb; border-radius: 30px; margin: 40px 0; }
  .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; padding: 0 40px; }
  .details-card h4 { font-size: 1.2rem; margin-bottom: 20px; color: var(--primary-dark); font-weight: 800; }
  .check-list li, .info-list li { margin-bottom: 12px; font-size: 0.9rem; color: var(--grey-text); list-style: none; display: flex; align-items: center; }
  .check-list li::before { content: "✓"; color: var(--primary); font-weight: 900; margin-right: 12px; }
  .info-list li::before { content: "•"; color: var(--primary); margin-right: 12px; }
  .restricted-item { color: #991b1b !important; font-weight: 700; background: #fef2f2; padding: 10px; border-radius: 8px; border: 1px dashed #fecaca; }

  .faq-section { padding: 60px 0; border-top: 1px solid #eee; }
  .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px; }
  .faq-item { background: var(--white); padding: 25px; border-radius: 15px; border: 1px solid #f3f4f6; }
  .faq-item h3 { font-size: 1.1rem; color: var(--dark); margin-bottom: 12px; font-weight: 700; line-height: 1.3; }
  .faq-item p { font-size: 0.95rem; color: var(--grey-text); line-height: 1.6; }

  .contact-split { 
    display: grid; grid-template-columns: 1fr 1.2fr; gap: 40px; 
    background: var(--dark); color: var(--white); padding: 50px; border-radius: 30px; align-items: center;
  }
  .contact-info-side h4 { font-size: 1.8rem; color: var(--primary); margin-bottom: 15px; font-weight: 800; }
  .whatsapp-link { 
    display: inline-block; color: #25d366; text-decoration: none; font-size: 1.1rem; 
    font-weight: 800; margin-top: 20px; border: 1.5px solid rgba(37, 211, 102, 0.3); padding: 12px 24px; border-radius: 12px;
  }

  @media (max-width: 950px) {
    .hero-grid, .details-grid, .contact-split, .faq-grid { grid-template-columns: 1fr; }
    .hero-clean-title { font-size: 1.8rem; min-height: auto; }
    .gallery-square-grid { max-width: 350px; margin: 0 auto; }
  }
</style>