<style>
  /* --- Contenedores y Base --- */
  .container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  .text-center { text-align: center; }
  
  /* --- Hero Single Column --- */
  .hero-clean { padding: 80px 0 40px 0; background: #fff; text-align: center; }
  .hero-single-column { max-width: 850px; margin: 0 auto; }
  .hero-clean h1 { font-size: 2.8rem; color: #111; margin-bottom: 25px; line-height: 1.1; font-weight: 800; }
  .lead { font-size: 1.25rem; color: #333; line-height: 1.6; margin-bottom: 20px; }

  /* --- Estilo de Secciones de Texto --- */
  .pricing-expert, .solutions-section { padding: 50px 0; }
  .benefits-grid p { margin-bottom: 15px; border-left: 3px solid #00a69c; padding-left: 15px; }

  /* --- Promo Box --- */
  .promo-section { padding: 40px 0; }
  .promo-content { background: #f0fdfa; padding: 35px; border-radius: 20px; border: 1px solid #ccfbf1; }

  /* --- FORMULARIO PREMIUM CENTRADO --- */
  .form-display-section { padding: 60px 0; background-color: #fcfcfc; }
  .centered-flex { display: flex; justify-content: center; }
  .form-premium-card { 
    background: #ffffff;
    padding: 40px;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    border: 1px solid #eaeaea;
    width: 100%;
    max-width: 550px;
  }
  .form-title { text-align: center; color: #00a69c; margin-bottom: 25px; font-size: 1.6rem; font-weight: 700; }

  /* --- Galería --- */
  .gallery-custom-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 200px; 
    gap: 20px;
    margin-top: 40px;
  }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; border-radius: 12px; }
  .gallery-item.vertical { grid-row: span 2; }

  @media (max-width: 768px) {
    .hero-clean h1 { font-size: 2.2rem; }
    .gallery-custom-grid { grid-template-columns: repeat(2, 1fr); }
    .form-premium-card { padding: 25px; }
  }
</style>