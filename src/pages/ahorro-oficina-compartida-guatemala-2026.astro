<style>
  /* --- Contenedores Base --- */
  .container { max-width: 1150px; margin: 0 auto; padding: 0 20px; }
  .text-center { text-align: center; }
  
  /* --- Secciones con Formulario (Split Sections) --- */
  .salas-split-section, .oficinas-split-section {
    padding: 60px 0;
    background-color: #fcfcfc;
  }

  .grid-two-columns {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 50px;
    align-items: center; /* Cambiado a center para mejor balance visual */
  }

  /* --- AJUSTE ULTRA-COMPACTO DEL FORMULARIO --- */
  .contact-form { 
    padding: 15px 20px !important; /* Relleno mínimo */
    max-width: 420px;
    margin-left: auto;
  }

  .form-group { 
    margin-bottom: 8px !important; /* Espacio mínimo entre campos */
  }

  .form-group label { 
    margin-bottom: 2px !important; 
    font-size: 0.85rem !important; /* Etiquetas más pequeñas */
    color: #555;
  }

  .form-group input, 
  .form-group textarea, 
  .form-group select { 
    padding: 6px 12px !important; /* Inputs más delgados */
    font-size: 0.9rem !important;
  }

  .form-group textarea {
    height: 60px !important; /* Altura muy reducida para el mensaje */
    min-height: 60px !important;
  }

  .btn-submit { 
    padding: 10px 20px !important; /* Botón más bajo */
    font-size: 0.95rem !important;
    margin-top: 5px !important;
  }

  /* --- Textos Educativos / Beneficios --- */
  .educational-column h2 {
    color: #00a69c;
    font-size: 2rem;
    margin-bottom: 25px;
    line-height: 1.2;
  }

  .benefit-item {
    margin-bottom: 20px;
    border-left: 4px solid #00a69c;
    padding-left: 15px;
  }

  .benefit-item p, .benefits-info p {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #444;
    margin: 0;
  }

  /* --- Hero Section --- */
  .hero-clean { padding: 60px 0; background: #fff; }
  .hero-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 50px; align-items: center; }
  .img-hero { width: 100%; height: auto; aspect-ratio: 1/1; object-fit: cover; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
  .hero-clean h1 { font-size: 2.5rem; color: #1a1a1a; margin-bottom: 20px; line-height: 1.2; }
  .lead { font-size: 1.15rem; color: #666; line-height: 1.6; margin: 0; }

  /* --- SECCIÓN DE PLANES --- */
  .pricing-expert { padding: 60px 0; background: #fcfcfc; }
  .grid-3, .grid-2-centered { 
    display: flex; 
    flex-wrap: wrap; 
    justify-content: center; 
    gap: 25px; 
    margin-bottom: 25px; 
  }

  .card { 
    background: white; 
    padding: 30px 25px; 
    border-radius: 15px; 
    border: 1px solid #eee; 
    text-align: center; 
    flex: 1; 
    min-width: 300px; 
    max-width: 350px; 
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  }
  
  .card.featured { border: 2px solid #00a69c; position: relative; }
  .badge { background: #00a69c; color: white; padding: 5px 15px; border-radius: 20px; font-size: 0.8rem; position: absolute; top: -12px; left: 50%; transform: translateX(-50%); }
  .price { font-size: 1.5rem; font-weight: bold; margin: 15px 0; color: #1a1a1a; }
  .card ul { text-align: left; padding: 0; list-style: none; margin: 20px 0; }
  .card ul li::before { content: "•"; color: #00a69c; font-weight: bold; margin-right: 8px; }

  /* --- Botones --- */
  .btn { display: inline-block; padding: 12px 25px; background: #00a69c; color: white; text-decoration: none; border-radius: 8px; font-weight: bold; width: 100%; text-align: center; transition: 0.3s; }
  .btn:hover { opacity: 0.9; transform: translateY(-2px); }

  /* --- Galería Asimétrica --- */
  .gallery-custom-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 200px; 
    gap: 20px;
    margin-top: 40px;
  }

  .gallery-item img { width: 100%; height: 100%; object-fit: cover; border-radius: 12px; transition: 0.3s; }
  .gallery-item.vertical { grid-row: span 2; }

  /* --- Promo Box --- */
  .promo-box { background: #00a69c; border: 2px dashed #ffffff; padding: 25px; border-radius: 10px; text-align: center; color: white; margin-top: 30px; }

  /* --- Media Queries --- */
  @media (max-width: 950px) {
    .grid-two-columns, .hero-grid { grid-template-columns: 1fr; text-align: center; }
    .educational-column h2 { font-size: 1.75rem; }
    .benefit-item { border-left: none; border-bottom: 2px solid #00a69c; padding: 0 0 10px 0; }
    .gallery-custom-grid { grid-template-columns: repeat(2, 1fr); }
    .contact-form { margin: 0 auto; }
  }

  @media (max-width: 550px) {
    .gallery-custom-grid { grid-template-columns: 1fr; grid-auto-rows: 250px; }
    .gallery-item.vertical { grid-row: span 1; }
  }
</style>