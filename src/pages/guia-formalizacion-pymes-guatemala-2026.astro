---
import MainLayout from '../layouts/MainLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const currentCanonicalURL = "https://todoesdigital.com/guia-formalizacion-pymes-guatemala-2026";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Guía 2026: Cómo Formalizar tu Empresa con Oficinas Virtuales en Guatemala",
  "description": "Comparativa y requisitos para obtener dirección fiscal ante la SAT y Registro Mercantil.",
  "author": { "@type": "Organization", "name": "Todo es Digital" },
  "datePublished": "2026-02-22"
};
---

<MainLayout 
  title="Guía 2026: Cómo Formalizar tu Empresa con Oficinas Virtuales en Guatemala"
  description="Formaliza tu empresa ante la SAT. Comparativa visual de negocio formal vs. informal con oficina virtual."
  canonicalURL={currentCanonicalURL}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />

  <div class="container-formalizacion">
    <main class="content-wrapper">
      
      <header class="header-section">
        <h1 class="main-title">
          Guía de Formalización con <span class="text-teal">Oficinas Virtuales</span>
        </h1>
      </header>

      <section class="comparison-grid">
        
        <div class="column">
          <div class="tarjeta-visual informal">
            <div class="sello-informal">INFORMAL</div>
            <div class="tarjeta-inner">
              <div class="tarjeta-top">
                <h3 class="biz-name-card">Consultores Profesionales SA</h3>
                <p class="owner-name-card">Jorge Perez</p>
              </div>
              <div class="tarjeta-bottom text-slate">
                <p>📍 Valles del bosque, casa 4</p>
                <p>📞 +502 30459080</p>
                <p>✉️ consultoresvarios@gmail.com</p>
              </div>
            </div>
          </div>
          <p class="label-caption">Estado Actual</p>
        </div>

        <div class="column">
          <div class="tarjeta-visual profesional">
            <div class="tarjeta-inner">
              <div class="tarjeta-top">
                <h3 class="biz-name-card text-cyan">Consultores Profesionales SA</h3>
                <div class="divider-cyan"></div>
                <p class="owner-name-card text-white">Jorge Perez</p>
                <p class="job-title-card">Gerente General</p>
              </div>
              <div class="tarjeta-bottom text-slate-light">
                <p><span class="text-cyan">DIR:</span> Zona Pradera, torre 2 oficina 1108</p>
                <p><span class="text-cyan">PBX:</span> +502 23022299</p>
                <p><span class="text-cyan">MAIL:</span> gerencia@consultoresprofesionales.com</p>
              </div>
            </div>
            <div class="glow-effect"></div>
          </div>
          <p class="label-caption text-teal-bold">Con Oficina Virtual</p>
        </div>

      </section>

      <div class="footer-content-grid">
        <div class="prose-area">
          <h2 class="section-subtitle">Formalización ante la SAT</h2>
          <p class="description-text">
            La diferencia entre ambas tarjetas es la confianza que generas en tus clientes. Una <strong>oficina virtual en Guatemala</strong> no es solo una dirección; es el respaldo legal y comercial que tu empresa necesita para crecer.
          </p>
        </div>
        <aside class="sidebar-form">
           <div class="form-card">
             <h3 class="form-title">¿Quieres formalizarte?</h3>
             <ContactForm serviceName="Guia Formalizacion" formId="mgolzeyp" />
           </div>
        </aside>
      </div>
    </main>
  </div>
</MainLayout>

<style>
  /* RESET Y ESTRUCTURA BASE */
  .container-formalizacion {
    width: 100%;
    padding: 4rem 1rem;
    background-color: white;
  }
  .content-wrapper {
    max-width: 1100px;
    margin: 0 auto;
  }
  .text-teal { color: #0d9488; }
  .text-cyan { color: #22d3ee; }
  .main-title {
    font-size: 3rem;
    font-weight: 900;
    text-align: center;
    margin-bottom: 4rem;
    color: #0f172a;
  }

  /* EL GRID QUE NO FALLA */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* DOS COLUMNAS IGUALES */
    gap: 3rem;
    margin-bottom: 5rem;
  }

  .column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* DISEÑO DE TARJETA */
  .tarjeta-visual {
    width: 400px;
    height: 230px;
    border-radius: 12px;
    position: relative;
    padding: 2rem;
    box-sizing: border-box;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  .informal {
    background-color: white;
    border: 2px solid #e2e8f0;
  }

  .profesional {
    background-color: #2d3136;
    color: white;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .tarjeta-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    z-index: 10;
  }

  .biz-name-card { font-weight: bold; font-size: 1.15rem; margin: 0; }
  .owner-name-card { font-size: 1.25rem; font-weight: 900; margin-top: 0.5rem; }
  .job-title-card { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 2px; color: #94a3b8; }
  .divider-cyan { width: 80px; height: 3px; background-color: #22d3ee; margin: 0.5rem 0; }
  .tarjeta-bottom { font-size: 0.85rem; line-height: 1.4; }
  
  .sello-informal {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%) rotate(-15deg);
    border: 5px solid rgba(239, 68, 68, 0.1);
    color: rgba(239, 68, 68, 0.1);
    font-size: 4rem;
    font-weight: 900;
    pointer-events: none;
    z-index: 1;
  }

  .label-caption { margin-top: 1rem; font-weight: bold; font-size: 0.8rem; text-transform: uppercase; color: #94a3b8; }
  .text-teal-bold { color: #0d9488; }

  /* FOOTER GRID */
  .footer-content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    border-top: 1px solid #e2e8f0;
    padding-top: 4rem;
  }

  .section-subtitle { font-size: 2rem; font-weight: bold; margin-bottom: 1.5rem; }
  .description-text { font-size: 1.125rem; color: #475569; line-height: 1.6; }
  .form-card { background-color: #f8fafc; padding: 2rem; border-radius: 1rem; border: 1px solid #f1f5f9; }
  .form-title { font-size: 1.25rem; font-weight: bold; margin-bottom: 1rem; }

  /* RESPONSIVO */
  @media (max-width: 900px) {
    .comparison-grid, .footer-content-grid {
      grid-template-columns: 1fr;
    }
    .tarjeta-visual {
      width: 100%;
      max-width: 400px;
    }
  }
</style>