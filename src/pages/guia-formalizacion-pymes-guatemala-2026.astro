---
import MainLayout from '../layouts/MainLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const currentCanonicalURL = "https://todoesdigital.com/guia-formalizacion-pymes-guatemala-2026";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Guía 2026: Cómo Formalizar tu Empresa con Oficinas Virtuales en Guatemala",
  "description": "Comparativa y requisitos para obtener dirección fiscal ante la SAT y Registro Mercantil.",
  "author": { "@type": "Organization", "name": "Todo es Digital" },
  "datePublished": "2026-02-22"
};
---

<MainLayout 
  title="Guía 2026: Cómo Formalizar tu Empresa con Oficinas Virtuales en Guatemala"
  description="Formaliza tu empresa ante la SAT. Comparativa visual de negocio formal vs. informal con oficina virtual."
  canonicalURL={currentCanonicalURL}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />

  <div class="container mx-auto px-4 py-16">
    <main class="max-w-6xl mx-auto">
      
      <header class="text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-black text-slate-900 leading-tight mb-6">
          Guía de Formalización con <span class="text-teal-600">Oficinas Virtuales</span>
        </h1>
      </header>

      <section class="mb-24">
        <h2 class="text-2xl font-bold text-center text-slate-800 mb-12 uppercase">Comparativa: Informal vs. Profesional</h2>
        
        <div class="grid md:grid-cols-2 gap-10 items-center justify-items-center">
          
          <div class="card-business card-informal">
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-20">
              <span class="informal-stamp">Informal</span>
            </div>
            <div class="relative z-10 h-full flex flex-col justify-between">
              <div>
                <h3 class="text-slate-700 text-xl font-serif">Consultores Profesionales SA</h3>
                <p class="text-slate-800 font-bold text-base mt-2">Jorge Perez</p>
              </div>
              <div class="text-slate-500 text-[13px] leading-relaxed">
                <p>📍 Valles del bosque, casa 4</p>
                <p>📞 +502 30459080</p>
                <p>✉️ consultoresvarios@gmail.com</p>
              </div>
            </div>
          </div>

          <div class="card-business card-pro">
            <div class="absolute -bottom-3 -right-3 z-30 bg-cyan-400 text-white px-3 py-1 rounded shadow-lg text-[10px] font-black animate-pulse">
              VERIFIED ADDRESS
            </div>
            <div class="relative z-10 h-full flex flex-col justify-between text-white">
              <div>
                <h3 class="text-white text-xl font-serif">Consultores Profesionales SA</h3>
                <div class="w-24 h-0.5 bg-cyan-400 my-3"></div>
                <p class="text-white font-bold text-base leading-none">Jorge Perez</p>
                <p class="text-cyan-400 text-[9px] uppercase tracking-widest mt-1">Gerente General</p>
              </div>
              <div class="text-slate-300 text-[13px] leading-relaxed space-y-1">
                <p><span class="text-cyan-400 font-bold text-[10px] mr-1">DIR:</span> Zona Pradera, torre 2 oficina 1108</p>
                <p><span class="text-cyan-400 font-bold text-[10px] mr-1">PBX:</span> +502 23022299</p>
                <p><span class="text-cyan-400 font-bold text-[10px] mr-1">MAIL:</span> gerencia@consultoresprofesionales.com</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="grid lg:grid-cols-3 gap-16 border-t pt-16">
        <div class="lg:col-span-2 prose prose-lg">
          <h2 class="text-3xl font-bold">Formalización ante la SAT</h2>
          <p>Obtén el respaldo legal que tu empresa necesita ante la SAT con nuestras oficinas virtuales.</p>
        </div>
        <aside class="lg:col-span-1">
           <ContactForm serviceName="Guia Formalizacion" formId="mgolzeyp" />
        </aside>
      </div>
    </main>
  </div>
</MainLayout>

<style>
  /* ESTILOS DE TARJETA GARANTIZADOS */
  .card-business {
    width: 100%;
    max-width: 420px;
    height: 240px;
    padding: 2rem;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  }

  .card-informal {
    background-color: #fdfdfb;
    border: 1px solid #e2e8f0;
    opacity: 0.8;
  }

  .card-pro {
    background-color: #2d3136;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    transform: scale(1.05);
  }

  .informal-stamp {
    border: 3px solid rgba(220, 38, 38, 0.3);
    color: rgba(220, 38, 38, 0.3);
    font-size: 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    transform: rotate(-15deg);
    padding: 0.5rem 1rem;
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .card-pro {
        transform: scale(1);
    }
  }
</style>