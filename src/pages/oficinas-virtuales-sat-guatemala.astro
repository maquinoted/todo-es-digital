---
import MainLayout from '../layouts/MainLayout.astro';
const currentCanonicalURL = "https://todoesdigital.com/oficinas-virtuales-guatemala";
import ContactForm from '../components/ContactForm.astro';
---

<MainLayout 
  title="Oficinas Virtuales para SAT en Guatemala: Dirección Fiscal Zona 10"
  description="Formalice su empresa ante la SAT con nuestra oficina virtual. Obtenga dirección fiscal legal en un centro empresarial de prestigio en Zona 10."
  canonicalURL={currentCanonicalURL}
>
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "name": "Oficinas Virtuales para SAT",
        "provider": {
          "@type": "LocalBusiness",
          "name": "Todo es Digital",
          "url": "https://todoesdigital.com"
        },
        "description": "Servicio de dirección fiscal y comercial en Guatemala para trámites ante la SAT y Registro Mercantil.",
        "areaServed": {
          "@type": "Country",
          "name": "Guatemala"
        }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "¿Qué es el domicilio fiscal según la SAT?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Según el Artículo 114 del Código Tributario de Guatemala, es el lugar físico localizable que el contribuyente designa para recibir notificaciones y cumplir obligaciones tributarias."
            }
          },
          {
            "@type": "Question",
            "name": "¿Se puede usar una oficina virtual para la SAT?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Sí, siempre que la oficina virtual proporcione una ubicación física real, verificable y con contrato de arrendamiento legal, como el que ofrece Todo es Digital."
            }
          }
        ]
      }
    ]
  }
  </script>

  <section class="hero-clean">
    <div class="container">
      <h1>Oficinas Virtuales para SAT: Su Dirección Fiscal Legal en Guatemala</h1>
      <p class="lead">
        Obtener su <strong>dirección fiscal para la <a href="https://portal.sat.gob.gt/" target="_blank" rel="noopener noreferrer">SAT</a></strong> es el requisito número uno para operar legalmente. En <strong>Todo es Digital</strong>, facilitamos el proceso de <strong>formalizar una empresa en Guatemala</strong>.
      </p>
    </div>
  </section>

  <section class="definition-sat">
    <div class="container">
      <div class="sat-quote-box">
        <h3>¿Por qué elegir una Oficina Virtual para su trámite de SAT?</h3>
        <p>
          De acuerdo con el <strong>Artículo 114 del Código Tributario de Guatemala</strong>, el domicilio fiscal es el lugar que el contribuyente designa para el cumplimiento de sus obligaciones tributarias y para recibir notificaciones. Para la <strong>SAT</strong>, este debe ser un lugar físico localizable donde se presuma que se desarrolla la actividad económica.
        </p>
        <p class="legal-note">
          Nuestra <strong>oficina virtual en Zona Pradera</strong> cumple estrictamente con este requisito, proporcionando una ubicación física real y verificable.
        </p>
      </div>
    </div>
  </section>

  <section class="legal-steps">
    <div class="container">
      <h3>Pasos para obtener su Domicilio Fiscal con Todo es Digital</h3>
      <p class="intro-legal">
        Basado en el <strong>Decreto 6-91</strong>, estos son los pasos esenciales para establecer su sede legal:
      </p>

      <div class="steps-grid">
        <div class="step-card">
          <span class="step-number">01</span>
          <h3>Contrato de Arrendamiento</h3>
          <p>La SAT requiere respaldo del uso del inmueble. Nuestras <strong>oficinas virtuales</strong> le proporcionan un contrato legal firmado para este fin.</p>
        </div>

        <div class="step-card">
          <span class="step-number">02</span>
          <h3>Actualización de RTU Digital</h3>
          <p>Debe realizar la actualización en su <strong>Agencia Virtual SAT</strong>, indicando la ubicación exacta que le asignamos.</p>
        </div>

        <div class="step-card">
          <span class="step-number">03</span>
          <h3>Documentación de Soporte</h3>
          <p>Tener listos requisitos como el DPI del Representante Legal, acta de constitución y el recibo de servicios que facilitamos.</p>
        </div>

        <div class="step-card">
          <span class="step-number">04</span>
          <h3>Ratificación de Domicilio</h3>
          <p>Garantizamos que su empresa esté localizable en <strong>Zona Pradera</strong> para cualquier verificación de la administración tributaria.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="conversion-split">
    <div class="container grid-2">
      <div class="text-column">
        <h2>¿Por qué usar una oficina virtual para su dirección fiscal?</h2>
        <p>
          Para cumplir con los <strong>requisitos para formalizar una empresa en Guatemala</strong>, la SAT exige una ubicación verificable. Nuestra <strong>oficina virtual guatemala</strong> le otorga ese respaldo jurídico en el mejor <strong>centro empresarial zona 10</strong>.
        </p>
        
        <div class="internal-link-box">
          <p>¿Busca planes corporativos generales? Conozca todos nuestros servicios de <a href="/oficinas-virtuales-guatemala">oficinas virtuales en Guatemala</a> aquí.</p>
        </div>
      </div>
      
      <div class="form-column">
        <ContactForm serviceName="Oficinas Virtuales SAT" formId="mgolzeyp" />
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .container { max-width: 1150px; margin: 0 auto; padding: 0 20px; }
  
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: start; padding: 60px 0; }

  .hero-clean { padding: 60px 0; background: #fff; text-align: center; }
  .lead { font-size: 1.2rem; color: #444; max-width: 800px; margin: 0 auto; }
  .lead a { color: #007a73; font-weight: bold; }

  .definition-sat { padding: 40px 0; background: #fff; }
  .sat-quote-box { 
    background: #f8fafc; 
    border-left: 5px solid #007a73; 
    padding: 30px; 
    border-radius: 0 10px 10px 0; 
  }
  .sat-quote-box h3 { color: #007a73; margin-bottom: 15px; font-size: 1.4rem; }
  .legal-note { margin-top: 15px; font-style: italic; font-weight: 600; color: #006b64 !important; }

  .legal-steps { padding: 60px 0; background: #f9f9f9; }
  .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; margin-top: 30px; }
  
  /* AJUSTES PARA PAGESPEED ACCESIBILITY */
  .step-card { 
    background: white; 
    padding: 25px; 
    border-radius: 12px; 
    border-top: 5px solid #006b64; /* Verde más oscuro */
    box-shadow: 0 4px 10px rgba(0,0,0,0.05); 
  }
  .step-number { 
    font-size: 1.5rem; 
    font-weight: 900; 
    color: #006b64; /* Verde sólido sin opacidad para contraste */
    display: block; 
    margin-bottom: 10px; 
  }

  .internal-link-box {
    background: #f0fdfa;
    padding: 20px;
    border-radius: 10px;
    border: 1px solid #007a73;
    margin: 30px 0;
  }
  .internal-link-box a { font-weight: bold; color: #007a73; }

  @media (max-width: 900px) {
    .grid-2 { grid-template-columns: 1fr; gap: 30px; }
    .text-column { text-align: center; }
  }
</style>