---
import MainLayout from '../layouts/MainLayout.astro';

// Solo agrega estas 4 variables. No toques nada más arriba.
const title = "Todo es Digital | Oficinas Virtuales y PBX Cloud en Guatemala";
const description = "Potencie su empresa con domicilio fiscal en Zona Pradera, PBX Cloud y atención profesional desde Q150. Ahorre un 90% en costos operativos hoy.";
const keywords = "oficina virtual guatemala, pbx cloud guatemala, domicilio fiscal sat, salas de reuniones zona 10, direccion comercial zona pradera";
const canonicalURL = "https://todoesdigital.com";
---

<MainLayout 
  title={title}
  description={description}
  keywords={keywords}
  canonicalURL={canonicalURL}
>
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://todoesdigital.com/#webpage",
      "url": "https://todoesdigital.com/",
      "name": "Todo es Digital - Servicios de oficinas en Guatemala",
      "description": "Oficinas virtuales, salas de reuniones y espacios de coworking en Guatemala.",
      "publisher": {
        "@type": "Organization",
        "name": "Todo es Digital",
        "logo": {
          "@type": "ImageObject",
          "url": "https://todoesdigital.com/salas-reuniones-renta-guatemala.webp"
        }
      },
      "datePublished": "2024-01-01T08:00:00-06:00",
      "dateModified": "2026-03-04T00:00:00-06:00"
    }
  ]
}
</script>
  <section class="hero">
    <div class="hero-content">
      <h1>Todo es digital | oficinas virtuales en Guatemala</h1>
      <p>
        Potencie la imagen de su empresa con una <strong>oficina virtual en Guatemala</strong> que combina prestigio y ahorro. En Todo es Digital, te ofrecemos una solución todo incluido con <strong>domicilio fiscal y comercial</strong> en una de las ubicaciones más exclusivas del país, ideal para trámites de SAT y representación profesional. Olvídese de los altos costos administrativos, el pago de servicios y contratos de arrendamiento complejos; aquí obtiene una estructura corporativa completa diseñada para que se enfoque únicamente en hacer crecer su negocio mientras nosotros gestionamos su oficina.
      </p>
    </div>
    <div class="hero-image">
      <img 
        src="/recepcionista-oficina-virtual-guatemala.webp" 
        alt="Recepcionista profesional de oficina virtual en Guatemala" 
        width="600" 
        height="400"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <section class="business-growth">
  <div class="container">
    <div class="section-intro">
      <span class="badge">Crezca con nosotros</span>
      <h2>Servicios de oficina en Guatemala para llevar su negocio al siguiente nivel</h2>
      <p>Infraestructura corporativa con el respaldo del centro empresarial más estratégico de Guatemala.</p>
    </div>

    <div class="services-grid">
      <div class="column featured-card">
        <div class="price-badge">Desde <strong>Q150</strong> mensuales</div>
        <h2>Oficinas Virtuales</h2>
        <p>
          Formalice su empresa con el servicio de <strong>oficina virtual</strong> más completo de Guatemala. Proyecte la seriedad que sus clientes buscan con una <strong>dirección fiscal</strong> y comercial de prestigio en Zona Pradera, ideal para trámites de SAT. 
          Su plan incluye un sistema de <strong>PBX Cloud</strong> de última generación, <strong>recepcionista</strong> profesional para su atención telefónica y <strong>manejo de correspondencia</strong>. 
          Además, obtenga acceso a <strong>salas de reuniones</strong> equipadas y beneficios exclusivos como <strong>descuento en parqueo</strong>.
        </p>
        <a href="/oficinas-virtuales-guatemala" class="btn-internal">Ver planes de oficina virtual →</a>
      </div>

      <div class="column">
        <div class="price-badge">Desde <strong>Q75</strong> el día</div>
        <h2>Coworking</h2>
        <p>
          Trabaje en el centro de negocios más exclusivo. Espacios compartidos en <strong>Zona Pradera</strong> con internet simétrico, café ilimitado y el mejor ambiente profesional. Ideal para nómadas digitales y consultores que buscan una sede corporativa en la <strong>zona 10</strong>.
        </p>
        <a href="/coworking-guatemala" class="btn-internal secondary">Ver coworking en Guatemala →</a>
      </div>

      <div class="column">
        <div class="price-badge">Desde <strong>Q100</strong> por hora</div>
        <h2>Salas de Reuniones</h2>
        <p>
          Contamos con espacios modernos y equipados en el corazón de la zona 10 para sus juntas, presentaciones o entrevistas. 
          Nuestras salas ofrecen un ambiente privado, profesional, con <strong>Wifi de alta velocidad</strong> y servicio de <strong>agua y café</strong> incluido para garantizar el éxito de sus reuniones de negocios.
        </p>
        <a href="/alquiler-salas-reuniones-guatemala" class="btn-internal secondary">Ver salas de reuniones →</a>
      </div>
    </div>
  </div>
</section>

<style is:inline>
  .business-growth {
    padding: 60px 20px;
    background-color: #f9f9f9;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .section-intro {
    text-align: center;
    margin-bottom: 30px;
  }
  .section-intro h2 {
    font-size: 2.2rem;
    color: #424243;
    max-width: 800px;
    margin: 10px auto;
  }
  .badge {
    background: #e0e0e0;
    color: #424243;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  /* Ajustado para 3 columnas equilibradas */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .column {
    background: #fff;
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    border: 1px solid #eee;
    transition: transform 0.3s ease;
  }

  .featured-card {
    border-top: 6px solid #424243;
  }

  .price-badge {
    background: #f0f0f0;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 0.85rem;
    margin-bottom: 15px;
    align-self: flex-start;
  }
  .price-badge strong { font-size: 1.1rem; color: #424243; }

  .column h2 {
    color: #424243;
    margin-bottom: 12px;
    font-size: 1.8rem;
  }

  .column p {
    color: #666;
    line-height: 1.6;
    margin-bottom: 20px;
    flex-grow: 1;
    font-size: 0.95rem;
  }

  .btn-internal {
    text-decoration: none;
    color: white;
    background-color: #424243;
    padding: 12px 25px;
    border-radius: 5px;
    text-align: center;
    font-weight: 700;
    transition: background 0.3s;
  }
  
  .btn-internal.secondary {
    background-color: transparent;
    color: #424243;
    border: 2px solid #424243;
  }

  .btn-internal:hover {
    filter: brightness(1.2);
  }

  @media (max-width: 992px) {
    .services-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
    .section-intro h2 { font-size: 1.4rem; }
    .business-growth { padding: 40px 20px; }
  }
</style>

<section class="efficiency-section">
  <div class="container">
    <div class="efficiency-header">
      <h2>Maximice su rentabilidad con infraestructura y tecnología.</h2>
      <p>
        En el ecosistema empresarial de Guatemala, el éxito no depende de cuánto gasta, sino de qué tan inteligente es su inversión. Nuestra solución está diseñada para el empresario que busca <strong>ahorro operativo</strong> sin sacrificar la calidad del servicio que recibe.
      </p>
    </div>

    <div class="efficiency-grid">
      <div class="efficiency-card">
        <h3>Inversión Inteligente vs. Gasto Fijo</h3>
        <p>
          Reduzca sus costos operativos hasta en un <strong>90%</strong> en comparación con el arrendamiento de una oficina convencional en Guatemala. Al elegir nuestra modalidad de oficina virtual o salas de reuniones por hora, dia o semana, usted elimina el peso de facturas de servicios, mantenimiento y contratos a largo plazo, pagando únicamente por lo que su negocio necesita para operar.
        </p>
        <ul class="benefit-list">
          <li><strong>Cero inversión inicial:</strong> Olvídese de depósitos de garantía y mobiliario.</li>
          <li><strong>Escalabilidad total:</strong> Crezca su plan conforme aumenten sus clientes.</li>
        </ul>
      </div>

      <div class="efficiency-card highlight-card">
        <h3>Movilidad Total con PBX Cloud</h3>
        <p>
          Su oficina no es un lugar físico, es donde usted esté. Con nuestro sistema de <strong>PBX Cloud en Guatemala</strong>, usted nunca perderá una oportunidad de negocio. Una <strong>recepcionista profesional</strong> atiende sus llamadas y las transfiere a su celular, brindando la imagen de una corporación establecida mientras usted mantiene total libertad de movimiento.
        </p>
        <ul class="benefit-list">
          <li><strong>Presencia Local:</strong> Un número de teléfono fijo de Guatemala que genera confianza inmediata.</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style is:inline>
  .efficiency-section {
    padding: 80px 20px;
    background-color: #ffffff;
    color: #424243;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .efficiency-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .efficiency-header h2 {
    font-size: 2.2rem;
    margin-bottom: 20px;
    color: #424243;
  }
  .efficiency-header p {
    font-size: 1.1rem;
    color: #666;
    max-width: 900px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .efficiency-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  .efficiency-card {
    padding: 40px;
    border-radius: 12px;
    background: #fdfdfd;
    border: 1px solid #eee;
    transition: transform 0.3s ease;
  }
  .highlight-card {
    background: #424243;
    color: white;
    border: none;
  }
  .highlight-card h3, .highlight-card p, .highlight-card li {
    color: white !important;
  }

  .efficiency-card h3 {
    font-size: 1.5rem;
    margin-bottom: 15px;
  }

  .benefit-list {
    margin-top: 20px;
    padding-left: 0;
    list-style: none;
  }
  .benefit-list li {
    margin-bottom: 10px;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .benefit-list li::before {
    content: "✓";
    color: #25d366;
    font-weight: bold;
  }

  @media (max-width: 850px) {
    .efficiency-grid { grid-template-columns: 1fr; }
  }
</style>

  <section class="location-section">
    <div class="container">
      <div class="location-grid">
        <div class="location-gallery">
          <div class="main-img-wrapper">
            <img 
              src="/oficinas-guatemala.webp" 
              alt="Lobby Empresarial Zona Pradera" 
              width="1200" 
              height="800"
              loading="lazy"
              decoding="async"
              class="main-location-img" 
            />
          </div>
          <div class="side-imgs">
            <img 
              src="/domicilio-fiscal-zona10-guatemala.webp" 
              alt="domicilio fiscal en guatemala zona 10" 
              width="600" 
              height="400"
              loading="lazy"
              decoding="async"
            />
            <img 
              src="/direccion-fiscal-zona-10-guatemala.webp" 
              alt="Direccion fiscal y comercial oficina virtual Guatemala" 
              width="600" 
              height="400"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>


        <div class="location-content">
          <div class="section-badge">Ubicación Premium</div>
          <h3>¿Por qué establecer su oficina virtual en Zona Pradera?</h3>
          <p class="location-desc">
            Establezca su empresa en el centro empresarial más importante y estratégico de la ciudad de Guatemala. 
            Posiciónese junto a las empresas más reconocidas, prestigiosas y estables del país.
          </p>

          <div class="amenities-grid">
            <div class="amenity-item">
              <span class="amenity-icon">📍</span>
              <div>
                <strong>Ubicación estratégica</strong>
                <p>Fácil acceso desde cualquier punto de la ciudad.</p>
              </div>
            </div>
            <div class="amenity-item">
              <span class="amenity-icon">🛡️</span>
              <div>
                <strong>Máxima Seguridad</strong>
                <p>Sistemas de control de acceso y vigilancia 24/7.</p>
              </div>
            </div>
            <div class="amenity-item">
              <span class="amenity-icon">🚗</span>
              <div>
                <strong>Amplio Parqueo</strong>
                <p>Comodidad garantizada para usted y sus clientes.</p>
              </div>
            </div>
            <div class="amenity-item">
              <span class="amenity-icon">✨</span>
              <div>
                <strong>Prestigio Corporativo</strong>
                <p>La mejor carta de presentación para sus aliados de negocio.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
</MainLayout>

<style is:inline>
  .hero {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 60px 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-content { flex: 1.2; }
  
  .hero-content h1 {
    font-size: 2.5rem;
    color: #424243;
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .hero-content p {
    font-size: 1.1rem;
    color: #666;
    line-height: 1.6;
  }

  .hero-image { 
    flex: 1; 
    display: flex;
    justify-content: center;
  }

  .hero-image img {
    width: 100%;
    max-width: 600px;
    height: auto;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .location-section {
    padding: 80px 20px;
    background-color: #fcfcfc;
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .location-gallery {
    display: flex;
    gap: 15px;
  }
  .main-img-wrapper { flex: 2; }
  .main-location-img {
    width: 100%;
    height: 450px;
    object-fit: cover;
    border-radius: 15px;
  }
  .side-imgs {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .side-imgs img {
    width: 100%;
    height: 217px;
    object-fit: cover;
    border-radius: 12px;
  }

  .section-badge {
    display: inline-block;
    background: #424243;
    color: white;
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }

  .amenities-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 25px;
  }

  .amenity-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .amenity-icon {
    font-size: 1.4rem;
    background: white;
    padding: 12px;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }

  @media (max-width: 992px) {
    .location-grid { grid-template-columns: 1fr; }
    .location-gallery { order: 2; }
    .location-content { order: 1; }
  }

  @media (max-width: 768px) {
    .hero { 
      flex-direction: column; 
      text-align: center; 
      padding: 40px 20px; 
      gap: 30px;
    }
    .hero-content h1 { font-size: 2rem; }
    .hero-image { width: 100%; }
  }

  @media (max-width: 600px) {
    .location-gallery { flex-direction: column; }
    .main-location-img, .side-imgs img { height: 250px; }
  }
</style>